# Template for .env used by docker-compose.yml — copy and adjust:
#   cp .env.example .env
# Every value has the same default in docker-compose.yml, so .env is only
# needed to override.

DAGSTER_WEB_PORT=3000

# MinIO connection (from inside containers, host.docker.internal = the host)
MINIO_ENDPOINT_URL=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
BUCKET_URL=s3://evd/

# evd_screening — the KRCS Data Capture Forms (Frappe) API it pulls from.
# Issued by the Frappe administrator against a dedicated `EVD Lake Reader`
# service account. Required only if you run the evd_screening source.
# Use https in anything but local dev: the token is sent in a request header.
EVD_SCREENING_BASE_URL=https://forms.krcs.example/api/method/
EVD_SCREENING_API_KEY=
EVD_SCREENING_API_SECRET=
